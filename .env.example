# ===== Google Drive =====
# วาง JSON ของ service account ทั้งก้อนใน 1 บรรทัด (escaped) หรือใช้ GOOGLE_APPLICATION_CREDENTIALS ชี้ไฟล์
GOOGLE_APPLICATION_CREDENTIALS=/secrets/service-account.json
# โฟลเดอร์เริ่มต้น (override ได้จากหน้า Admin)
DRIVE_DEFAULT_FOLDER_ID=

# ===== Admin =====
ADMIN_PASSWORD=changeme
SESSION_SECRET=please-change-this-to-a-long-random-string

# ===== Redis / Queue =====
REDIS_URL=redis://redis:6379

# ===== SQLite =====
# Path สำหรับไฟล์ SQLite — ต้อง shared ระหว่าง web+worker (mount เป็น tmpfs ใน docker-compose
# → behavior เทียบเท่า in-memory: หายเมื่อ VM/container หยุด)
SQLITE_PATH=/data/db.sqlite

# ===== Face processing =====
FACE_MODELS_PATH=/app/models
# resize เป้าหมาย (px) ก่อน detect — เร็วขึ้น 3-5x
FACE_RESIZE_WIDTH=800
# ระยะ embedding ที่ถือว่า match (0 = เหมือนเป๊ะ, ปกติ 0.4-0.5)
FACE_MATCH_THRESHOLD=0.5

# ===== Drive sync =====
# poll Drive ทุก N วินาที
DRIVE_POLL_INTERVAL_SEC=20

# ===== Web =====
NEXT_PUBLIC_APP_NAME=Face Photo Search
NEXT_PUBLIC_BRAND_COLOR=#0ea5e9
