# ===== Google Drive =====
# วาง service account JSON ที่ secrets/service-account.json — หรือชี้ path เองด้วยตัวแปรนี้
# GOOGLE_APPLICATION_CREDENTIALS=./secrets/service-account.json
# โฟลเดอร์เริ่มต้น (override ได้จากหน้า Admin)
DRIVE_DEFAULT_FOLDER_ID=

# ===== Admin =====
ADMIN_PASSWORD=changeme
SESSION_SECRET=please-change-this-to-a-long-random-string-32+

# ===== SQLite =====
# ค่า default: ./apps/web/data/db.sqlite (สร้างให้อัตโนมัติ)
# SQLITE_PATH=./data/db.sqlite

# ===== Face processing =====
# FACE_MODELS_PATH=./models
# resize เป้าหมาย (px) ก่อน detect — เร็วขึ้น 3-5x
FACE_RESIZE_WIDTH=800
# ระยะ embedding ที่ถือว่า match (0 = เหมือนเป๊ะ; face-api default = 0.6 สำหรับ "คนเดียวกัน")
# ค่าต่ำ = strict (เจอน้อย, แม่นยำสูง) / ค่าสูง = loose (เจอเยอะ, อาจปนคนอื่น)
FACE_MATCH_THRESHOLD=0.6
# จำนวน worker thread ที่ embedding พร้อมกัน (default = CPU - 1)
# FACE_CONCURRENCY=2

# ===== Drive sync =====
# poll Drive ทุก N วินาที
DRIVE_POLL_INTERVAL_SEC=20

# ===== Web =====
NEXT_PUBLIC_APP_NAME=Face Photo Search

# ===== App mode =====
# portable = single-process, single admin (เดิม), ติดตั้งบน Win/Mac ของช่างภาพ
# saas     = multi-tenant, มี super-admin + sub-admin หลายคน, ติดตั้งบน server
APP_MODE=portable

# ===== Google OAuth (saas mode เท่านั้น — ปล่อยว่างใน portable) =====
# ทำที่ console.cloud.google.com → OAuth 2.0 Client ID (Web application)
# - Authorized redirect URI ต้องเป็น <PUBLIC_URL>/api/oauth/google/callback
# - Production ต้อง HTTPS (Google policy บังคับ)
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=https://your-domain.com/api/oauth/google/callback
